{
    // general
    "editor.bracketPairColorization.enabled": true,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": true,
    "editor.cursorSurroundingLines": 8,
    "editor.fontLigatures": true,
    "editor.guides.bracketPairs": "active",
    "editor.linkedEditing": true,
    "editor.minimap.enabled": false,
    "editor.smoothScrolling": true,
    "explorer.autoReveal": false,
    "extensions.ignoreRecommendations": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "search.smartCase": true,
    "telemetry.telemetryLevel": "off",
    "window.commandCenter": false,
    // "window.density.editorTabHeight": "compact",
    "window.restoreWindows": "none",
    "workbench.activityBar.location": "top",
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.editor.enablePreview": false,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 10,
    "workbench.editor.showTabs": "none",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.layoutControl.enabled": false,
    "workbench.list.smoothScrolling": true,
    "workbench.productIconTheme": "material-product-icons",
    "workbench.settings.editor": "json",
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,

    "files.watcherExclude": {
        "**/node_modules": true,
        "**/.bare": true,
        "**/build": true,
        "**/dist": true,
        "**/out": true,
        "**/target": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.bare": true,
        "**/build": true,
        "**/dist": true,
        "**/out": true,
        "**/target": true
     },

    // vim
    "vim.foldfix": true,
    "vim.incsearch": true,
    "vim.hlsearch": true,
    "vim.leader": "<space>",
    "vim.smartRelativeLine": true,
    "vim.useSystemClipboard": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["<Esc>"],
            "commands": [":nohlsearch"],
            "when": "editorTextFocus",
            "silent": true
        },
        {
            "before": ["<leader>", "w"],
            "commands": [":w!"]
        },
        {
            "before": ["<leader>", "q"],
            "commands": [":q!"]
        },
        {
            "before": ["<leader>", "e"],
            "commands": ["workbench.view.explorer"]
        },
        {
            "before": ["<leader>", "<space>"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<leader>", "/"],
            "commands": ["workbench.action.quickTextSearch"]
        },
        {
            "before": ["<leader>", ","],
            "commands": ["workbench.action.showAllEditors"]
        },
        {
            "before": ["<leader>", "s", "s"],
            "commands": ["workbench.action.gotoSymbol"]
        },
        {
            "before": ["<leader>", "s", "S"],
            "commands": ["workbench.action.showAllSymbols"]
        },
        {
            "before": ["<leader>", "-"],
            "commands": ["workbench.action.splitEditorDown"]
        },
        {
            "before": ["<leader>", "|"],
            "commands": ["workbench.action.splitEditorRight"]
        },
        {
            "before": ["K"],
            "commands": ["editor.action.showHover"],
            "when": "editorTextFocus && vim.mode == 'Normal'"
        },
        {
            "before": ["g", "r", "d"],
            "commands": ["editor.action.revealDefinition"]
        },
        {
            "before": ["g", "r", "D"],
            "commands": ["editor.action.revealDeclaration"]
        },
        {
            "before": ["g", "r", "i"],
            "commands": ["editor.action.goToImplementation"]
        },
        {
            "before": ["g", "r", "a"],
            "commands": ["editor.action.quickFix"]
        },
        {
            "before": ["g", "r", "r"],
            "commands": ["editor.action.referenceSearch.trigger"]
        },
        {
            "before": ["g", "r", "o"],
            "commands": ["editor.action.goToTypeDefinition"]
        },
        {
            "before": ["g", "r", "n"],
            "commands": ["editor.action.rename"]
        },
        {
            "before": ["g", "r", "f"],
            "commands": ["editor.action.formatDocument"]
        },
        {
            "before": ["[", "d"],
            "commands": ["editor.action.marker.prev"]
        },
        {
            "before": ["]", "d"],
            "commands": ["editor.action.marker.next"]
        },
        {
            "before": ["[", "b"],
            "commands": ["workbench.action.previousEditorInGroup"]
        },
        {
            "before": ["]", "b"],
            "commands": ["workbench.action.nextEditorInGroup"]
        },
        {
            "before": ["[", "c"],
            "commands": ["workbench.action.editor.previousChange"]
        },
        {
            "before": ["]", "c"],
            "commands": ["workbench.action.editor.nextChange"]
        },
        {
            "before": ["<leader>", "g", "g"],
            "commands": ["workbench.view.scm"]
        },
        {
            "before": ["<leader>", "h", "s"],
            "commands": ["git.stageSelectedRanges"]
        },
        {
            "before": ["<leader>", "h", "r"],
            "commands": ["git.revertSelectedRanges"]
        },
        {
            "before": ["<leader>", "h", "u"],
            "commands": ["git.unstageSelectedRanges"]
        },
        {
            "before": ["<leader>", "h", "S"],
            "commands": ["git.stage"]
        },
        {
            "before": ["<leader>", "h", "U"],
            "commands": ["git.unstage"]
        },
        {
            "before": ["<leader>", "h", "R"],
            "commands": ["git.clean"]
        },
        {
            "before": ["<leader>", "h", "p"],
            "commands": ["editor.action.dirtydiff.next"]
        },
        {
            "before": ["<leader>", "h", "d"],
            "commands": ["git.openChange"]
        },
        {
            "before": ["<C-d>"],
            "commands": [
                { "command": "editorScroll", "args": { "to": "down", "by": "halfPage", "revealCursor": true } }
            ]
        },
        {
            "before": ["<C-u>"],
            "commands": [
                { "command": "editorScroll", "args": { "to": "up", "by": "halfPage", "revealCursor": true } }
            ]
        },
        {
            "before": ["<c-h>"],
            "commands": ["workbench.action.navigateLeft"]
        },
        {
            "before": ["<c-j>"],
            "commands": ["workbench.action.navigateDown"]
        },
        {
            "before": ["<c-k>"],
            "commands": ["workbench.action.navigateUp"]
        },
        {
            "before": ["<c-l>"],
            "commands": ["workbench.action.navigateRight"]
        },
    ],

    // extensions
    "claudeCode.preferredLocation": "panel",
    "projectManager.git.baseFolders": [
        "$home/Developer/projects",
        "$home/dev/projects",
    ],
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1,
    },
}