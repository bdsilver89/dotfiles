{
    "breadcrumbs.enabled": true,
    "breadcrumbs.icons": true,
    "breadcrumbs.symbolPath": "off",
    "claudeCode.preferredLocation": "sidebar",
    "editor.copyWithSyntaxHighlighting": false,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.guides.bracketPairs": "active",
    "editor.hideCursorInOverviewRuler": true,
    "editor.lineNumbers": "relative",
    "editor.linkedEditing": true,
    "editor.glyphMargin": true,
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.overviewRulerBorder": false,
    "editor.quickSuggestions": { "strings": false },
    "editor.showFoldingControls": "mouseover",
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": true,
    "editor.suggest.insertMode": "replace",
    // "editor.roundedSelection": true,
    "explorer.confirmDragAndDrop": false,
    "explorer.fileNesting.enabled": true,
    "extensions.ignoreRecommendations": true,
    "extensions.experimental.affinity": {
        "vscodevim.vim": 1
    },
    "git.confirmSync": true,
    "git.detectSubmodules": false,
    "git.openRepositoryInParentFolders": "always",
    "git.autoStash": true,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    // "gitlens.statusBar.enabled": false,
    "gitlens.blame.avatars": false,
    "gitlens.blame.heatmap.enabled": false,
    "gitlens.hovers.currentLine.enabled": false,
    "gitlens.hovers.annotations.enabled": false,
    "gitlens.showWhatsNewAfterUpgrades": false,
    "gitlens.plusFeatures.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": true,
        "tags": true,
        "worktrees": true,
        "contributors": true,
        "fileHistory": false,
        "repositories": true,
        "searchAndCompare": false,
        "launchpad": true
    },
    "projectManager.git.baseFolders": [
        "~/dev/projects",
        "~/Developer/projects"
    ],
    "projectManager.git.ignoredFolders": [".bare"],
    "projectManager.git.maxDepthRecursion": 2,
    "projectManager.sortList": "Recent",
    "remote.extensionKind": {
        "alefragnani.project-manager": ["workspace"]
    },
    "security.workspace.trust.untrustedFiles": "open",
    "scm.defaultViewMode": "tree",
    "scm.diffDecorations": "gutter",
    "telemetry.telemetryLevel": "off",
    "window.commandCenter": false,
    // "window.density.editorTabHeight": "compact",
    // "workbench.editor.showTabs": "single",
    "window.menuBarVisibility": "compact",
    "window.titleBarStyle": "custom",
    "window.zoomLevel": 0,
    "workbench.activityBar.location": "top",
    "workbench.browser.showInTitleBar": false,
    "workbench.colorTheme": "Catppuccin Mocha",
    "workbench.editor.empty.hint": "hidden",
    "workbench.editor.enablePreview": false,
    // "workbench.editor.decorations.badges": false,
    // "workbench.editor.decorations.colors": false,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.layoutControl.enabled": false,
    "workbench.list.smoothScrolling": true,
    "workbench.statusBar.visible": true,
    "workbench.settings.editor": "json",
    "workbench.startupEditor": "none",
    "workbench.productIconTheme": "material-product-icons",
    "workbench.tips.enabled": false,
    "workbench.tree.renderIndentGuides": "none",
    "vim.leader": "<space>",
    "vim.foldfix": true,
    "vim.handleKeys": {
        "<C-d>": true,
        "<C-s>": false,
        "<C-z>": false,
        "<C-p>": false
    },
    "vim.highlightedyank.enable": true,
    "vim.hlsearch": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["<Esc>"],
            "commands": [":nohl"],
            "when": "editorFocus",
            "silent": true
        },
        {
            "before": ["<leader>", "<space>"],
            "commands": ["workbench.action.quickOpen"]
        },
        {
            "before": ["<leader>", "/"],
            "commands": ["workbench.action.findInFiles"]
        },
        {
            "before": ["<leader>", "s", "s"],
            "commands": ["workbench.action.gotoSymbol"]
        },
        {
            "before": ["<leader>", "s", "S"],
            "commands": ["workbench.action.showAllSymbols"]
        },
        {
            "before": ["<leader>", ","],
            "commands": ["workbench.action.showAllEditors"]
        },
        {
            "before": ["<leader>", "-"],
            "commands": ["workbench.action.splitEditorDown"]
        },
        {
            "before": ["<leader>", "|"],
            "commands": ["workbench.action.splitEditorRight"]
        },
        {
            "before": ["z", "a"],
            "commands": ["editor.toggleFold"]
        },
        {
            "before": ["<leader>", "w"],
            "commands": ["workbench.action.files.save"]
        },
        {
            "before": ["<leader>", "q"],
            "commands": ["workbench.action.closeActiveEditor"]
        },
        {
            "before": ["<leader>", "e"],
            "commands": ["workbench.view.explorer"]
        },
        {
            "before": ["<leader>", "g", "g"],
            "commands": ["workbench.view.scm"]
        },
        {
            "before": ["<leader>", "g", "b"],
            "commands": ["gitlens.toggleFileBlame"]
        },
        {
            "before": ["<leader>", "g", "h"],
            "commands": ["gitlens.showQuickFileHistory"]
        },
        {
            "before": ["<leader>", "g", "l"],
            "commands": ["gitlens.showQuickCommitFileDetails"]
        },
        {
            "before": ["<leader>", "g", "o"],
            "commands": ["gitlens.openFileOnRemote"]
        },
        {
            "before": ["<leader>", "d"],
            "commands": ["workbench.view.debug"]
        },
        {
            "before": ["K"],
            "commands": ["editor.action.showHover"]
        },
        {
            "before": ["g", "r", "d"],
            "commands": ["editor.action.revealDefinition"]
        },
        {
            "before": ["g", "r", "D"],
            "commands": ["editor.action.revealDeclaration"]
        },
        {
            "before": ["g", "r", "i"],
            "commands": ["editor.action.goToImplementation"]
        },
        {
            "before": ["g", "r", "a"],
            "commands": ["editor.action.quickFix"]
        },
        {
            "before": ["g", "r", "r"],
            "commands": ["editor.action.referenceSearch.trigger"]
        },
        {
            "before": ["g", "r", "o"],
            "commands": ["editor.action.goToTypeDefinition"]
        },
        {
            "before": ["g", "r", "n"],
            "commands": ["editor.action.rename"]
        },
        {
            "before": ["g", "r", "f"],
            "commands": ["editor.action.formatDocument"]
        },
        {
            "before": ["[", "d"],
            "commands": ["editor.action.marker.prev"]
        },
        {
            "before": ["]", "d"],
            "commands": ["editor.action.marker.next"]
        },
        {
            "before": ["[", "b"],
            "commands": ["workbench.action.previousEditor"]
        },
        {
            "before": ["]", "b"],
            "commands": ["workbench.action.nextEditor"]
        },
        {
            "before": ["<c-h>"],
            "commands": ["workbench.action.navigateLeft"]
        },
        {
            "before": ["<c-j>"],
            "commands": ["workbench.action.navigateDown"]
        },
        {
            "before": ["<c-k>"],
            "commands": ["workbench.action.navigateUp"]
        },
        {
            "before": ["<c-l>"],
            "commands": ["workbench.action.navigateRight"]
        }
    ]
}