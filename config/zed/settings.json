{
  "sticky_scroll": {
    "enabled": false
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "material-icon-theme": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": "Catppuccin Macchiato",
  "icon_theme": "Material Icon Theme",
  "buffer_font_family": ".ZedMono",
  "buffer_font_size": 14,
  "ui_font_family": ".ZedSans",
  "title_bar": {
    "show_onboarding_banner": false,
    "show_sign_in": false
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
  },
  "project_panel": {
    "default_width": 400,
    "hide_root": true,
    "auto_fold_dirs": true
  },
  "collaboration_panel": {
    "button": false
  },
  "file_finder": {
    "modal_max_width": "large"
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never"
    },
  },
  "git_panel": {
    "tree_view": true,
    "default_width": 300,
  },
  "git": {
    "worktree_directory": ".."
  },
  "colorize_brackets": true,
  "format_on_save": "off",
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },

