{
  "diff_view_style": "unified",
  "project_panel": {
    "hide_root": false
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "material-icon-theme": true,
    "java": true,
    "html": true,
    "dockerfile": true,
    "toml": true,
    "sql": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "theme": "Catppuccin Macchiato",
  "icon_theme": "Material Icon Theme",
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_branch_name": true,
    "show_user_menu": true,
    "show_sign_in": false,
  },
